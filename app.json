{
  "expo": {
    "name": "JustKlick",
    "slug": "justklick_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Jk.png",
    "scheme": "justklickapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/Jk.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/Jk.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.himavamsigumpu.justklick_app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Jk.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/Jk.png",
          "imageWidth": 1
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
